# Persistent pnpm settings for this project.
# Reason: user's environment proxies HTTP through a single channel; pnpm's default
# parallel fetch (16 connections) triggers ECONNRESET on the proxy.
network-concurrency=2
fetch-retries=5
fetch-retry-mintimeout=5000
fetch-retry-maxtimeout=60000

# Allow non-TTY runs to purge node_modules without confirmation prompt.
confirm-modules-purge=false

# Skip auto re-install before each pnpm-run command. We manage installs explicitly,
# and the auto-check triggers a TTY confirmation that breaks Tauri's pre-dev hook.
verify-deps-before-run=false

# Skip lifecycle scripts (preinstall/install/postinstall/prepare) during install.
# Reason: pnpm 11 errors on unapproved build scripts (esbuild) even when listed in
# onlyBuiltDependencies — known interaction with workspace yaml. esbuild ships its
# linux-x64 binary as an optional dep, so skipping the postinstall is harmless.
ignore-scripts=true
